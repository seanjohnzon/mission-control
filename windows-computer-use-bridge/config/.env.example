BRIDGE_API_KEY=replace-with-strong-key
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8000

# Anthropic runner configuration
# Set ANTHROPIC_API_KEY to enable the production Anthropic-backed task runner.
# Omit (or set BRIDGE_RUNNER=demo) to run in safe demo mode with no API calls.
#ANTHROPIC_API_KEY=sk-ant-...
#BRIDGE_RUNNER=demo       # force demo mode even if ANTHROPIC_API_KEY is set
#BRIDGE_RUNNER=anthropic  # require Anthropic runner (errors if SDK/key missing)
